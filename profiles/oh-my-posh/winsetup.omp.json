{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
      {
        "type": "prompt",
        "newline": true,
        "alignment": "left",
        "segments": []
      },
      {
        "type": "prompt",
        "newline": true,
        "alignment": "left",
        "segments": [
          {
            "foreground": "#AE00FB",
            "template": "  {{ .Name }} ",
            "properties": {
              "mapped_shell_names": {
                "pwsh": "pwsh",
                "powershell": "powershell",
                "cmd": "cmd",
                "bash": "bash"
              }
            },
            "style": "plain",
            "type": "shell"
          },
          {
            "foreground": "#06FF00",
            "foreground_templates": [
              "{{ if .Root }}#FF1700{{ end }}"
            ],
            "template": " {{ if .SSHSession }}{{ else }}{{ end }} {{ .UserName }} ",
            "style": "plain",
            "type": "session"
          },
          {
            "foreground": "#FBB454",
            "foreground_templates": [
              "{{ if or (.Working.Changed) (.Staging.Changed) }}#F7EC09{{ end }}",
              "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#ff5700{{ end }}",
              "{{ if gt .Ahead 0 }}#16c60c{{ end }}",
              "{{ if gt .Behind 0 }}#f450de{{ end }}"
            ],
            "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ .BranchStatus }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }}",
            "properties": {
              "branch_max_length": 25,
              "fetch_stash_count": true,
              "fetch_status": true,
              "fetch_upstream_icon": true
            },
            "style": "plain",
            "type": "git"
          }
        ]
      },
      {
        "type": "prompt",
        "overflow": "hide",
        "alignment": "right",
        "segments": [
          {
            "foreground": "#AE00FB",
            "template": "{{ if .WSL }}WSL @ {{ end }}{{.Icon}} ",
            "properties": {
              "windows": ""
            },
            "style": "plain",
            "type": "os"
          },
          {
            "foreground": "#AE00FB",
            "template": "{{ .HostName }} ",
            "style": "plain",
            "type": "session"
          },
          {
            "foreground": "#56BBF1",
            "foreground_templates": [
              "{{if eq \"Charging\" .State.String}}#FBB454{{end}}",
              "{{if eq \"Discharging\" .State.String}}#FF1700{{end}}",
              "{{if eq \"Full\" .State.String}}#56BBF1{{end}}"
            ],
            "template": " {{ .Icon }} {{ .Percentage }}% ",
            "properties": {
              "charged_icon": "",
              "charging_icon": "",
              "discharging_icon": "",
              "not_charging_icon": ""
            },
            "style": "plain",
            "type": "battery"
          },
          {
            "foreground": "#F7EC09",
            "template": "  {{ .CurrentDate | date .Format }}",
            "properties": {
              "time_format": "15:04:03"
            },
            "style": "plain",
            "type": "time"
          }
        ]
      },
      {
        "type":"prompt",
        "newline": true,
        "overflow": "break",
        "alignment": "left",
        "segments": [
          {
            "foreground": "#56BBF1",
            "template": "  {{ .Path }}",
            "properties": {
              "style": "full"
            },
            "style": "plain",
            "type": "path"
          }
        ]
      },
      {
        "type": "prompt",
        "overflow": "break",
        "alignment": "right",
        "segments": [
          {
            "foreground": "#06FF00",
            "foreground_templates": [
              "{{ if gt .Code 0 }}#FF1700{{ end }}"
            ],
            "template": " {{ .FormattedMs }}",
            "properties": {
              "style": "roundrock",
              "always_enabled": true
            },
            "style": "plain",
            "type": "executiontime"
          }
        ]
      },
      {
        "type": "prompt",
        "newline": true,
        "alignment": "left",
        "segments": [
          {
            "foreground": "#06FF00",
            "foreground_templates": [
              "{{ if .Root }}#FF1700{{ end }}"
            ],
            "template": "{{ if .Root }}{{ else }}{{ end }}",
            "style": "plain",
            "type": "text"
          }
        ]
      } 
    ],
    "console_title_template": "{{ if .Root }}Admin: {{ end }}{{ .Folder }}",
    "final_space": true,
    "version": 2
  }
  